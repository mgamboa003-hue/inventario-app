# Renombrar a .env y completar los valores

# Clave secreta (generar una aleatoria larga). NO la dejes vacia en produccion:
# si no esta fija, las sesiones se invalidan cada vez que reinicia el servidor
# y se rompe con multiples workers de gunicorn.
SECRET_KEY=cambia_esto_por_una_clave_muy_larga_y_aleatoria

# Contraseña inicial del admin (se puede cambiar después desde la app)
ADMIN_PASSWORD=Wintec2024!

# Base de datos PostgreSQL (Railway/Render la proveen automáticamente)
# Dejar vacío para usar SQLite local
DATABASE_URL=

# Tamaño máximo de subida en MB
MAX_UPLOAD_MB=10

# Debug (solo en desarrollo)
DEBUG=False

# Forzar HTTPS y cookies seguras (activar SOLO cuando la app esta detras de
# un dominio con SSL, por ejemplo en Railway/Render). Dejar en False para uso local.
FORCE_HTTPS=False

# Intentos de login antes de bloquear la cuenta, y minutos de bloqueo
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Alertas de stock bajo por email (opcional) ---
# Si no se configuran SMTP_HOST y SMTP_TO, las alertas simplemente no se envian.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=inventario@wintec.local
SMTP_TO=

# --- Fotos en la nube via S3 / Cloudflare R2 (opcional) ---
# Si no se configuran, las fotos se siguen guardando en disco local como antes.
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_PUBLIC_URL=

# Cuantos backups locales conservar (backup_db.py)
BACKUPS_A_MANTENER=14

# --- Solicitudes del equipo (opcional, tienen valores por defecto) ---
# Dias de una solicitud pendiente antes de marcarla "Atrasada"
DIAS_ATRASO_SOLICITUD=5
# Dias que una solicitud Rechazada/Cancelada sigue en la lista activa antes de pasar solo al historial
DIAS_GRACIA_SOLICITUD=7

# --- Control de accesos (opcional) ---
# Minutos de inactividad tras los cuales una sesion deja de mostrarse como "En linea"
SESION_ACTIVA_MINUTOS=5
